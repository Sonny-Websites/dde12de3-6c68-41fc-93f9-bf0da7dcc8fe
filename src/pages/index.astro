---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Simple Landing Page',
  description: 'Small business-focused website and lead capture services.',
  areaServed: 'US'
};
---

<BaseLayout
  title="Simple Landing Page — Get started"
  description="A simple landing page for businesses that need a fast website and a clear contact form."
  ogTitle="Simple Landing Page — Get started"
  ogDescription="Simple websites, fast turnarounds, and an easy contact form."
  jsonLd={jsonLd}
>
  <Header current="home" />

  <main>
    <section class="hero" id="home" role="region" aria-labelledby="heroHeading">
      <div class="container hero-grid">
        <div>
          <p class="eyebrow">Small business web services</p>
          <h1 id="heroHeading">We help businesses get customers online.</h1>
          <p class="lead">Simple websites, fast turnarounds, and an easy contact form.</p>
          <div class="button-row">
            <a class="btn btn-primary" href="#contact">Get started</a>
          </div>
        </div>
        <div class="image-placeholder" aria-label="Hero Image Placeholder">Hero Image Placeholder</div>
      </div>
    </section>

    <section id="services" class="section" role="region" aria-labelledby="servicesHeading">
      <div class="container">
        <h2 id="servicesHeading">Services / What We Do</h2>
        <ul class="service-list">
          <li>Website design</li>
          <li>Lead capture forms</li>
          <li>Consultation &amp; setup</li>
        </ul>
      </div>
    </section>

    <section id="about" class="section section-muted" role="region" aria-labelledby="aboutHeading">
      <div class="container about-grid">
        <div>
          <h2 id="aboutHeading">About / Why Us</h2>
          <p>
            We are a small team focused on practical websites for local and growing businesses.
            Our process is straightforward: we set up a clear offer, build a fast page, and make it easy
            for customers to contact you.
          </p>
          <a class="btn btn-outline" href="#services">See services</a>
        </div>
        <div class="image-placeholder" aria-label="Team Photo Placeholder">Team Photo Placeholder</div>
      </div>
    </section>

    <section id="testimonials" class="section" role="region" aria-labelledby="testimonialsHeading">
      <div class="container">
        <h2 id="testimonialsHeading">Testimonials</h2>
        <div class="logo-row" aria-label="Placeholder logos">
          <span class="logo-chip">Company A Logo</span>
          <span class="logo-chip">Company B Logo</span>
        </div>
        <div class="testimonial-grid">
          <article class="card">
            <p>"Their landing page made it much easier for people to contact us online."</p>
            <p class="quote-source">Company A</p>
          </article>
          <article class="card">
            <p>"Fast turnaround and clear communication from start to launch."</p>
            <p class="quote-source">Company B</p>
          </article>
        </div>
      </div>
    </section>

    <section id="contact" class="section section-muted" role="region" aria-labelledby="contactHeading">
      <div class="container form-wrap">
        <h2 id="contactHeading">Contact</h2>
        <p class="contact-copy">Share your project details and we will follow up shortly.</p>

        <form id="contactForm" method="post" action="/__forms/contact" novalidate>
          <div class="form-group">
            <label for="name">Name <span aria-label="required">*</span></label>
            <input type="text" id="name" name="name" required aria-required="true" aria-describedby="nameError" />
            <span id="nameError" class="error-message"></span>
          </div>

          <div class="form-group">
            <label for="email">Email <span aria-label="required">*</span></label>
            <input type="email" id="email" name="email" required aria-required="true" aria-describedby="emailError" />
            <span id="emailError" class="error-message"></span>
          </div>

          <div class="form-group">
            <label for="phone">Phone (optional)</label>
            <input type="tel" id="phone" name="phone" aria-describedby="phoneError" />
            <span id="phoneError" class="error-message"></span>
          </div>

          <div class="form-group">
            <label for="message">Message <span aria-label="required">*</span></label>
            <textarea id="message" name="message" rows="5" required aria-required="true" aria-describedby="messageError"></textarea>
            <span id="messageError" class="error-message"></span>
          </div>

          <input type="hidden" name="site_id" value="nurzaman-temp" />
          <input type="hidden" name="forward_email" value="nurzaman.050810@gmail.com" />
          <input type="text" name="_hp" style="display:none" autocomplete="off" tabindex="-1" />

          <button type="submit" id="submitBtn" class="btn btn-primary" aria-busy="false">Send message</button>
        </form>
        <div id="responseMessage" role="alert" aria-live="polite"></div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
