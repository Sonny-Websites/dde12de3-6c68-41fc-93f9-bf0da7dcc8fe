---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<BaseLayout
  title="Thank You"
  description="Thank you for your message. We have received your inquiry."
  ogTitle="Thank You"
  ogDescription="Your message was sent successfully."
>
  <Header current="home" />
  <main>
    <section class="section" role="main" aria-labelledby="thankHeading">
      <div class="container">
        <h1 id="thankHeading">Thank you</h1>
        <p>Your message has been received. We will follow up soon.</p>
        <div class="button-row">
          <a href={base + '/'} class="btn btn-primary">Back to home</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
