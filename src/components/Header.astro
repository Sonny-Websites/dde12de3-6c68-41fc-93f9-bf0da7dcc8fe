---
interface Props {
  current?: 'home';
}

const { current } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<header role="banner">
  <nav class="container nav" role="navigation" aria-label="Main navigation">
    <a href={base + '/'} class="logo" aria-current={current === 'home' ? 'page' : undefined}>Simple Landing Page</a>
    <button class="hamburger" id="hamburgerMenu" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="navMenu">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul id="navMenu" class="nav-menu">
      <li><a href={base + '/#home'}>Home</a></li>
      <li><a href={base + '/#services'}>Services</a></li>
      <li><a href={base + '/#about'}>About</a></li>
      <li><a href={base + '/#testimonials'}>Testimonials</a></li>
      <li><a href={base + '/#contact'}>Contact</a></li>
    </ul>
  </nav>
</header>
